# AWS
AWS_PROFILE=agentcore-poc
AWS_REGION=us-east-1

# Bedrock model (Claude Sonnet 4.6 inference profile ID)
# Find exact ID in Bedrock console > Inference profiles
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Bedrock Knowledge Base (created via console - see scripts/setup_kb.md)
KB_ID=

# Tavily web search (sign up at https://tavily.com)
TAVILY_API_KEY=

# S3 bucket for input/output files (optional - local paths also supported)
S3_BUCKET=

# AgentCore Memory (created via scripts/setup_memory.py — run once and copy the
# printed MEMORY_ID here). Stores per-actor preferences and per-review summaries.
MEMORY_ID=
